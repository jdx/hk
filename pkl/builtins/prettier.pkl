import "../Builtins.pkl"
import "../Config.pkl"

@Builtins.meta {
  category = "JavaScript/TypeScript"
  description = "Opinionated code formatter"
  project_indicators {
    new { file = "package.json" }
  }
}
prettier = new Config.Step {
  glob =
    List(
      "**/*.js",
      "**/*.jsx",
      "**/*.mjs",
      "**/*.cjs",
      "**/*.ts",
      "**/*.tsx",
      "**/*.mts",
      "**/*.cts",
      "**/*.css",
      "**/*.scss",
      "**/*.less",
      "**/*.html",
      "**/*.json",
      "**/*.json5",
      "**/*.jsonc",
      "**/*.yaml",
      "**/*.yml",
      "**/*.markdown",
      "**/*.markdown.mdx",
      "**/*.md",
      "**/*.graphql",
      "**/*.handlebars",
      "**/*.svelte",
      "**/*.astro",
      "**/*.htmlangular",
      "**/*.vue",
    )
  batch = true
  check_diff =
    """
      failed=0
      for f in {{ files }}; do
        prettier "$f" | diff -u "$f" - || failed=1
      done
      exit $failed
    """
  check_list_files = "prettier --list-different {{ files }}"
  fix = "prettier --write {{ files }}"
  tests {
    ["check bad file"] {
      run = "check"
      write { ["{{tmp}}/a.json"] = #"{"b":1}"# }
      files = List("{{tmp}}/a.json")
      expect { code = 1 }
    }
    ["check good file"] {
      run = "check"
      write { ["{{tmp}}/a.json"] = #"{ "b": 1 }\#n"# }
      files = List("{{tmp}}/a.json")
      expect { code = 0 }
    }
    ["fix bad file"] {
      run = "fix"
      write { ["{{tmp}}/a.json"] = #"{"b":1}"# }
      files = List("{{tmp}}/a.json")
      expect {
        files { ["{{tmp}}/a.json"] = #"{ "b": 1 }\#n"# }
      }
    }
    ["fix good file"] {
      run = "fix"
      write { ["{{tmp}}/a.json"] = #"{ "b": 1 }\#n"# }
      files = List("{{tmp}}/a.json")
      expect {
        files { ["{{tmp}}/a.json"] = #"{ "b": 1 }\#n"# }
      }
    }
  }
}
