import "../Builtins.pkl"
import "../Config.pkl"
import "./test/helpers.pkl"

@Builtins.meta {
  category = "Rust"
  description = "Rust dependency linter"
  project_indicators {
    new { file = "deny.toml" }
    new { file = ".deny.toml" }
    new { file = ".cargo/deny.toml" }
    new { file = "deny.exceptions.toml" }
    new { file = ".deny.exceptions.toml" }
    new { file = ".cargo/deny.exceptions.toml" }
  }
}
cargo_deny = new Config.Step {
  glob =
    List(
      "**/Cargo.toml",
      "**/Cargo.lock",
      "**/deny.toml",
      "**/.deny.toml",
      "**/deny.exceptions.toml",
      "**/.deny.exceptions.toml",
    )
  workspace_indicator = "Cargo.toml"
  check = "cd {{workspace}} && cargo-deny --locked --workspace check"
  tests {
    local const testMaker = new helpers.TestMaker {
      filename = "deny.toml"
      extra_files = new Mapping<String, String> {
        ["src/lib.rs"] = ""
        ["Cargo.toml"] =
          """
          [package]
          name = "test"
          version = "0.1.0"
          edition = "2021"
          license = "MIT"

          """
        ["Cargo.lock"] =
          """
          # This file is automatically @generated by Cargo.
          # It is not intended for manual editing.
          version = 4

          [[package]]
          name = "test"
          version = "0.1.0"

          """
      }
    }
    ["check bad config"] = testMaker.checkFail("invalid = [\n", 1)
    ["check good config"] = testMaker.checkPass("[licenses]\nallow = [\"MIT\"]\n")
    ["check good dotfile config"] =
      testMaker.withFilename(".deny.toml").checkPass("[licenses]\nallow = [\"MIT\"]\n")
    ["check good cargo config"] =
      testMaker.withFilename(".cargo/deny.toml").checkPass("[licenses]\nallow = [\"MIT\"]\n")
  }
}
