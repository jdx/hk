import "../Builtins.pkl"
import "../Config.pkl"
import "./test/helpers.pkl"

@Builtins.meta {
  category = "JavaScript/TypeScript"
  description = "Oxidation compiler linter"
  project_indicators {
    new { file = "package.json"; contains = "\"oxlint\"" }
    // https://oxc.rs/docs/guide/usage/linter/config.html#create-a-config-file
    new { file = ".oxlintrc.json" }
    new { file = ".oxlintrc.jsonc" }
    new { file = "oxlint.config.ts" }
  }
}
ox_lint = new Config.Step {
  // Supported file types:
  //   https://oxc.rs/compatibility.html
  glob = List("**/*.js", "**/*.jsx", "**/*.ts", "**/*.tsx", "**/*.vue", "**/*.svelte", "**/*.astro")
  check = "oxlint {{ files }}"
  fix = "oxlint --fix {{ files }}"
  tests {
    local const testMaker = new helpers.TestMaker { filename = "foo.ts" }
    // Refernece: https://oxc.rs/docs/guide/usage/linter/rules/oxc/double-comparisons.html
    local const bad = "return (x === y || x < y);"
    local const good = "return (x <= y);"
    ["check bad file"] = testMaker.checkFail(bad, 1)
    ["check good file"] = testMaker.checkPass(good)
    ["fix bad file"] = testMaker.fixPass(bad, good)
    ["fix good file"] = testMaker.fixPass(good, good)
  }
}
