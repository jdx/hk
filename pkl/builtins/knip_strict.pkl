import "../Builtins.pkl"
import "../Config.pkl"
import "./test/helpers.pkl"

@Builtins.meta {
  category = "JavaScript/TypeScript"
  description = "Find unused files, dependencies, and exports with strict mode enabled"
}
knip_strict = new Config.Step {
  workspace_indicator = "package.json"
  // https://knip.dev/explanations/entry-files
  types = List("typescript", "javascript", "package.json")
  // Using `--strict` implies `--production`
  // https://knip.dev/features/production-mode#strict-mode
  check = "knip --strict --directory {{workspace}}"
  fix = "knip --fix --strict --directory {{workspace}}"
  tests {
    local const bad =
      """
        {
          "dependencies": {
            "express": "^4.18.0"
          }
        }

      """
    local const good =
      """
        {
           "dependencies": {}
        }

      """
    local const testMaker = new helpers.TestMaker {
      filename = "package.json"
      extra_files = new Mapping<String, String> {
        ["src/index.ts"] =
          """
            import type { Request, Response } from "express";

            export function handleRequest(req: Request): Response {
              console.log(req.body);
              return {} as Response;
            }
          """
      }
    }
    ["check bad file"] = testMaker.checkFail(bad, 1)
    ["check good file"] = testMaker.checkPass(good)
    // Once the commit (https://github.com/webpro-nl/knip/commit/c182c29e35748ff044048c578b6bf7dd99dae9a8)
    // is released, it will work as expected.
    ["fix bad file"] = testMaker.fixPass(bad, good)
    ["fix good file"] = testMaker.fixPass(good, good)
  }
}
